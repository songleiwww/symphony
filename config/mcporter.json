{
  "mcpServers": {
    "brightdata": {
      "command": "npx",
      "args": [
        "@brightdata/mcp"
      ],
      "env": {
        "API_TOKEN": "<FILL_IN_BRIGHTDATA_API_TOKEN>",
        "WEB_UNLOCKER_ZONE": "<FILL_IN_WEB_UNLOCKER_ZONE>",
        "BROWSER_AUTH": "<FILL_IN_BROWSER_AUTH>"
      }
    },
    "a2asearch": {
      "command": "npx",
      "args": [
        "-y",
        "a2asearch-mcp"
      ]
    },
    "astronomy-oracle": {
      "command": "npx",
      "args": [
        "-y",
        "astronomy-oracle"
      ]
    },
    "myinstants": {
      "command": "npx",
      "args": [
        "-y",
        "myinstants-mcp"
      ]
    },
    "photopea": {
      "command": "npx",
      "args": [
        "-y",
        "photopea-mcp-server"
      ]
    },
    "filesystem": {
      "command": "npx",
