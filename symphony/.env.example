# 序境Symphony AI 环境配置示例
# 复制此文件为 .env 并填写你的配置

# 服务器端口
# 开发默认: 18901
# 生产默认: 18789
# PORT=18901

# 运行环境
# NODE_ENV=development
# NODE_ENV=production

# 日志级别 (error/warn/info/debug)
# LOG_LEVEL=info

# 模型API密钥
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=xxx
# VOLCENGINE_API_KEY=xxx
# DEEPSEEK_API_KEY=xxx
