# 本地配置文件示例
# 复制此文件为 config.local.py 并填入你的真实API Key

# =============================================================================
# 本地API Key配置（复制为 config.local.py 使用）
# =============================================================================

# Cherry Doubao API Key
CHERRY_DOUBAO_API_KEY = "your_api_key_here"

# Cherry MiniMax API Key
CHERRY_MINIMAX_API_KEY = "your_api_key_here"

# Cherry NVIDIA API Key
CHERRY_NVIDIA_API_KEY = "your_api_key_here"

# Cherry ModelScope API Key
CHERRY_MODELSCOPE_API_KEY = "your_api_key_here"

# WeatherAPI Key
WEATHER_API_KEY = "your_weather_api_key"

# =============================================================================
# 本地覆盖配置
# =============================================================================

# 调试模式
DEBUG_MODE = False

# 日志级别
LOG_LEVEL = "INFO"

# 最大并发数
MAX_CONCURRENT = 5

# 请求超时（秒）
REQUEST_TIMEOUT = 30

# 最大重试次数
MAX_RETRIES = 3

# 是否启用所有模型
ENABLE_ALL_MODELS = True

# 启用的模型列表（留空表示全部启用）
ENABLED_MODELS = []

# 禁用的模型列表
DISABLED_MODELS = []

# 默认模型
DEFAULT_MODEL = "doubao_ark_code"

# 备用模型
FALLBACK_MODELS = [
    "doubao_deepseek_v32",
    "minimax_m25"
]

# =============================================================================
# 飞书配置（如果需要）
# =============================================================================

FEISHU_APP_ID = "your_feishu_app_id"
FEISHU_APP_SECRET = "your_feishu_app_secret"

# =============================================================================
# GitHub配置（如果需要）
# =============================================================================

GITHUB_TOKEN = "your_github_token"

# =============================================================================
# MCP服务器配置（如果需要）
# =============================================================================

MCP_SERVERS = {
    "tavily": {
        "enabled": False,
        "api_key": "your_tavily_api_key"
    },
    "brave_search": {
        "enabled": False,
        "api_key": "your_brave_api_key"
    }
}
