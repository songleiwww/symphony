  "workflow": [
    {
      "name": "full_imperial_process",
      "description": "完整皇权办事流程",
      "steps": [
        "emperor:decree",
        "neishi:deliver",
        "zhongshu_ling:accept",
        "sanqi_changshi:draft",
        "geishizhong:review",
        "if rejected → sanqi_changshi:revise",
        "liubu_langzhong:execute",
        "shiyushi:inspect",
        "if rejected → liubu_langzhong:rework",
        "qiju_lang:record",
        "shiguan_xiuzhuan:summary",
        "zhongshu_ling:report",
        "neishi:present",
        "emperor:approve",
        "case_closed"
      ]
    }
